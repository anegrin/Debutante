<resources>

    <style name="Theme.Debutante" parent="BaseTheme">
        <item name="mediaRouteTheme">@style/DebutanteMediaRouterTheme</item>
        <item name="actionBarStyle">@style/Widget.Debutante.ActionBar</item>
        <item name="windowActionBarOverlay">true</item>
    </style>

    <style name="Widget.Debutante.ActionBar" parent="Widget.Material3.ActionBar.Solid">
        <item name="background">@android:color/transparent</item>
        <item name="elevation">0dp</item>
        <item name="subtitleTextStyle">@style/TextAppearance.Debutante.ActionBar.Subtitle</item>
    </style>

    <style name="TextAppearance.Debutante.ActionBar.Subtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">12sp</item>
    </style>

    <style name="DebutanteMediaRouterTheme" parent="Theme.MediaRouter">
        <item name="mediaRouteButtonStyle">@style/DebutanteMediaRouteButtonStyle</item>
    </style>

    <style name="DebutanteMediaRouteButtonStyle" parent="Widget.MediaRouter.Light.MediaRouteButton">
        <item name="mediaRouteButtonTint">?attr/colorPrimary</item>
    </style>

    <style name="CircleAppearance">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="RoundedAppearance">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/spacing_large</item>
    </style>
</resources>
